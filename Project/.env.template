# ═══════════════════════════════════════════════════════
# Arsiv Decode — .env.template
# Bu dosyayı .env olarak kopyalayıp kendi yollarınızı girin.
# ═══════════════════════════════════════════════════════

# FFmpeg
FFMPEG_BIN_DIR=F:\Source\ffmpeg\bin

# API Keys
TMDB_API_KEY=
TMDB_BEARER_TOKEN=
TMDB_LANGUAGE=tr-TR

# Google Video Intelligence
GOOGLE_KEYS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# İsim Veritabanı
NAME_DB_DIR=F:\Source\name_db
SOURCE_ROOT=F:\Source

# Logolar
LOGOLAR_DIR=F:\Source\Logo

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL=qwen2.5vl:7b

# LLM Provider — "gemini" (default) veya "ollama"
# Gemini kullanmak için GEMINI_API_KEY ayarlayın.
# Ollama'ya geri dönmek için LLM_PROVIDER=ollama yapın.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com  # opsiyonel override

# HuggingFace (diarization için)
HF_TOKEN=

# VLM (Vision-Language Model) — OCR doğrulama ve opsiyonel VLM-as-OCR
# Varsayılan model: glm4.6v-flash:q4_K_M
# Kurulum: ollama pull glm4.6v-flash:q4_K_M
VLM_MODEL=glm4.6v-flash:q4_K_M
VLM_THRESHOLD=0.80
# VLM_ENABLED=true   # Doğrulamayı tamamen kapatmak için false yap

# Qwen Verifier (geriye dönük uyumluluk — VLM_MODEL yoksa kullanılır)
QWEN_MODEL=qwen3-vl:8b
QWEN_THRESHOLD=0.80

# OCR
OCR_LANG=tr
OCR_VERSION=