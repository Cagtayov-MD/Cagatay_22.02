# ═══════════════════════════════════════════════════════
# Arsiv Decode — .env.template
# Bu dosyayı .env olarak kopyalayıp kendi yollarınızı girin.
# Gerçek key'leri .env dosyasına koyun, template'e DEĞİL!
# ═══════════════════════════════════════════════════════

# FFmpeg
FFMPEG_BIN_DIR=F:\Source\ffmpeg\bin

# API Keys
TMDB_API_KEY=
TMDB_BEARER_TOKEN=
TMDB_LANGUAGE=tr-TR

# Google Video Intelligence
GOOGLE_KEYS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# İsim Veritabanı
NAME_DB_DIR=F:\Source\name_db
SOURCE_ROOT=F:\Source

# Logolar
LOGOLAR_DIR=F:\Source\Logo

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# LLM Provider — "gemini" (default) veya "ollama"
# Gemini kullanmak için GEMINI_API_KEY ayarlayın.
# Ollama'ya geri dönmek için LLM_PROVIDER=ollama yapın.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Experimental shadow Gemini film-credit sidecar
# Varsayilan kapali. Acmak icin: GEMINI_FILM_CREDIT_SHADOW_ENABLED=1
GEMINI_FILM_CREDIT_SHADOW_ENABLED=0
GEMINI_FILM_CREDIT_API_KEY=
GEMINI_FILM_CREDIT_MODEL=gemini-2.5-flash
# GEMINI_FILM_CREDIT_BASE_URL=https://generativelanguage.googleapis.com
# Expo TXT ciktisinin yazilacagi klasor (varsayilan: D:\expoOnay)
GEMINI_FILM_CREDIT_EXPO_DIR=D:\expoOnay

# HuggingFace (diarization için)
HF_TOKEN=

# VLM (Vision-Language Model) — OCR doğrulama ve opsiyonel VLM-as-OCR
# Varsayılan model: glm4.6v-flash:q4_K_M
# Kurulum: ollama pull glm4.6v-flash:q4_K_M
VLM_MODEL=glm4.6v-flash:q4_K_M
VLM_THRESHOLD=0.80
# VLM_ENABLED=true   # Doğrulamayı tamamen kapatmak için false yap

# Qwen Verifier (geriye dönük uyumluluk — VLM_MODEL yoksa kullanılır)
QWEN_MODEL=qwen3-vl:8b
QWEN_THRESHOLD=0.80

# OCR
OCR_LANG=tr
OCR_VERSION=

# Email bildirimleri (isteğe bağlı)
EMAIL_PASSWORD=

