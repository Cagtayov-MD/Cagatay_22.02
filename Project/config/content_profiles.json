    "audio_stages": ["detect_language", "extract", "transcribe"],
    "whisper_model": "large-v3",
    "whisper_language": "tr",
    "compute_type": "float16",
    "beam_size": 1,
    "ocr_enabled": true,
    "ocr_engine": "hybrid",
    "qwen_fallback_on_handwriting": true,
    "tmdb_enabled": true,
    "tmdb_person_verify": true,
    "user_report_mirror_dir": "D:\\export",
    "gemini_enabled": false,
    "llm_cast_filter": false,
    "blok2_enabled": false,
    "match_parse_enabled": false
  },
