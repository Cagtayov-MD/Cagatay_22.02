{
  "FilmDizi-Hybrid": {
    "_description": "Hibrit OCR: oneocr birincil motor + Qwen VLM handwriting/cursive fallback. Standard fontlarda oneocr tek başına yeterli; handwriting/cursive tespit edildiğinde Qwen tam frame okuma yapar.",
    "scope": "video+audio",
    "first_segment_minutes": 6,
    "last_segment_minutes": 10,
    "asr_sampling_mode": "first_middle_last",
